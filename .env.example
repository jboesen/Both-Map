ANTHROPIC_API_KEY=
CRON_SCHEDULE_HOURS=24

# Supabase (required)
SUPABASE_URL=               # e.g. https://abcdefg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=  # Settings → API → service_role key (keep secret, backend only)

# Optional features
PERPLEXITY_API_KEY=     # enables user research enrichment via Perplexity Sonar
ELEVENLABS_API_KEY=     # enables audio overview generation
ELEVENLABS_VOICE_ID=    # defaults to Rachel (21m00Tcm4TlvDq8ikWAM)
ELEVENLABS_MODEL_ID=    # defaults to eleven_turbo_v2_5

# NOTE: Substack credentials (URL, email, password) are now stored per-user
# in Supabase. They are submitted via POST /onboard, not env vars.
